{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Video Similarity",
  "version": "0.2.12",
  "identifier": "com.videosimilarity.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Video Similarity",
        "width": 1400,
        "height": 900,
        "minWidth": 960,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "center": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; img-src 'self' data: asset: http://asset.localhost https://asset.localhost; media-src 'self' asset: http://asset.localhost https://asset.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "$VIDEO/**/*",
            "$HOME/**/*",
            "$DESKTOP/**/*",
            "$DOCUMENT/**/*",
            "$DOWNLOAD/**/*",
            "$EXE/**/*",
            "$RESOURCE/**/*",
            "C:/**/*",
            "D:/**/*",
            "E:/**/*",
            "F:/**/*"
          ],
          "requireLiteralLeadingDot": false
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico", "icons/icon.png"],
    "resources": ["../../scripts", "../../video_sim", "../../requirements.txt", "../env"],
    "copyright": "",
    "category": "DeveloperTool",
    "shortDescription": "Video similarity analysis desktop app",
    "longDescription": "Desktop app for AI-assisted video similarity analysis"
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/RoamerFly/video-similarity-detector/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDEzRDI1QjdFMzcxODYwMjUKUldRbFlCZzNmbHZTRS9pM0t2WXAzc3hZNSszVU5VN0VjYkl5MG9zVkFKbmpQRGVvRzh0Y2xpWHUK",
      "dialog": false
    },
    "shell": {
      "open": true
    },
    "fs": {
      "requireLiteralLeadingDot": false
    }
  }
}
